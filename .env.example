# Configuration (copier en .env si besoin — .env n'est jamais commité).
# Stockage = SQLite (fichier local, aucun serveur). Chemin par défaut :
# data/wc2026.sqlite. Décommente pour changer l'emplacement.
# WC2026_DB_PATH=data/wc2026.sqlite

# Source des résultats de tableau (adaptateur ingestion/source_results.py)
# Valeurs : "none" (défaut) | "csv" | "football_data"
RESULTS_SOURCE=none
# Clé API football-data.org (free tier) — requise seulement si RESULTS_SOURCE=football_data
FOOTBALL_DATA_API_KEY=
